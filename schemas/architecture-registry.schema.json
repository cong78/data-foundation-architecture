{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/data-foundation/architecture-registry.schema.json",
  "title": "Data Foundation Architecture Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entities", "relationships"],
  "properties": {
    "schema_version": {"const": 1},
    "entities": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "title", "page"],
        "properties": {
          "type": {"enum": ["design", "service", "standard", "scenario"]},
          "title": {"type": "string", "minLength": 3},
          "page": {"type": "string", "pattern": "^[a-z0-9][a-z0-9./-]*\\.md(?:#[a-z0-9-]+)?$"}
        }
      }
    },
    "relationships": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "type", "target"],
        "properties": {
          "source": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "type": {"enum": ["implements", "depends_on", "constrained_by", "participates_in"]},
          "target": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"}
        }
      }
    }
  }
}
