{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "data-foundation-architecture-agent/request.schema.json",
  "title": "Architecture Agent Request",
  "type": "object",
  "required": ["task_id", "operation", "query", "actor", "purpose"],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "operation": {
      "enum": [
        "search_guidance",
        "resolve_definition",
        "classify_design",
        "trace_architecture",
        "prepare_context_pack"
      ]
    },
    "query": {"type": "string", "minLength": 2},
    "actor": {
      "type": "object",
      "required": ["id", "type"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "type": {"enum": ["named-user", "workload", "delegated-user"]}
      },
      "additionalProperties": false
    },
    "purpose": {"type": "string", "minLength": 2},
    "scope": {"type": "object", "additionalProperties": true},
    "context_references": {
      "type": "array",
      "items": {"type": "string"},
      "uniqueItems": true,
      "default": []
    },
    "top_k": {"type": "integer", "minimum": 1, "maximum": 10, "default": 5}
  },
  "additionalProperties": false
}
