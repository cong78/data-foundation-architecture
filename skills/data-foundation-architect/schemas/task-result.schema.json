{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "data-foundation-architect/task-result.schema.json",
  "title": "Data Foundation Architecture Task Result",
  "type": "object",
  "required": ["task_id", "capability", "status", "scope", "summary", "guidance_used"],
  "properties": {
    "task_id": {"type": "string"},
    "capability": {"enum": ["design", "review", "generate"]},
    "status": {"enum": ["draft", "partial", "blocked"]},
    "scope": {"type": "object"},
    "summary": {"type": "string"},
    "artifact": {"type": "string"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "title", "consequence", "correction"],
        "properties": {
          "severity": {"enum": ["Critical", "High", "Medium", "Low"]},
          "title": {"type": "string"},
          "consequence": {"type": "string"},
          "correction": {"type": "string"},
          "guidance": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "decisions": {"type": "array", "items": {"type": "string"}},
    "evidence_gaps": {"type": "array", "items": {"type": "string"}},
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "guidance_used": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
