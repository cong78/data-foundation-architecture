{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/data-contract-designer/compatibility-request.schema.json",
  "title": "Data Contract Compatibility Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "operation", "before", "after"],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "operation": {"const": "compatibility"},
    "before": {"type": "object"},
    "after": {"type": "object"},
    "known_consumers": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "evidence": {"type": "array", "items": {"type": "object"}}
  }
}
